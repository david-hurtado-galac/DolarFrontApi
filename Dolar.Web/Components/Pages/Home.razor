@page "/"
@inject HttpClient Http
@using System.Net.Http.Json
@rendermode InteractiveServer

<PageTitle>Tipo de Cambio</PageTitle>

<h1>Tipo de Cambio BCV</h1>

@if (_loading)
{
    <p>Cargando tasas de cambio...</p>
}
else if (_rates is null || _rates.Count == 0)
{
    <p>No se pudo cargar las tasas de cambio en este momento. Verifica que la API esté corriendo.</p>
}
else
{
    <div>
        @foreach (var r in _rates)
        {
            <div class="mb-3">
                <h2>@r.Currency: @r.Value</h2>
                <p>Actualizado: @r.RetrievedAt.ToString("g")</p>
                <p>Fuente: @r.Source</p>
                <p><small>@(r.IsCached ? "Desde caché" : "Reciente")</small></p>
            </div>
        }
    </div>
}

<button class="btn btn-primary" @onclick="RefreshAsync">Actualizar</button>

@code {
    private List<ExchangeRateDto>? _rates;
    private bool _loading;

    private readonly string[] _apiBaseUrls =
    [
        "https://localhost:7228",
        "http://localhost:7228",
        "https://localhost:7174",
        "http://localhost:5257",
        "https://localhost:5001",
        "http://localhost:5000"
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            foreach (var baseUrl in _apiBaseUrls)
            {
                try
                {
                    var endpoint = $"{baseUrl}/api/exchangerates/current";
                    var response = await Http.GetFromJsonAsync<List<ExchangeRateDto>>(endpoint);
                    if (response is not null && response.Count > 0)
                    {
                        _rates = response;
                        return;
                    }
                }
                catch (HttpRequestException)
                {
                    // Intentionally ignored; the next base URL will be tried.
                }
                catch (TaskCanceledException)
                {
                    // Intentionally ignored; the next base URL will be tried.
                }
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        try
        {
            foreach (var baseUrl in _apiBaseUrls)
            {
                try
                {
                    var endpoint = $"{baseUrl}/api/exchangerates/refresh";
                    var resp = await Http.PostAsJsonAsync(endpoint, new { });
                    if (resp.IsSuccessStatusCode)
                    {
                        // After a successful refresh, reload current rates
                        await LoadAsync();
                        return;
                    }
                }
                catch (HttpRequestException)
                {
                    // Intentionally ignored; the next base URL will be tried.
                }
                catch (TaskCanceledException)
                {
                    // Intentionally ignored; the next base URL will be tried.
                }
            }
        }
        finally
        {
            _loading = false;
        }
    }

    public class ExchangeRateDto
    {
        public string Currency { get; set; } = string.Empty;
        public decimal Value { get; set; }
        public DateTimeOffset RetrievedAt { get; set; }
        public string Source { get; set; } = string.Empty;
        public bool IsCached { get; set; }
    }
}
